// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STUDENT
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MaterialType {
  NOTES
  ASSIGNMENT
  PRACTICE_SHEET
  OTHER
}

model User {
  id       Int     @id @default(autoincrement())
  name     String
  email    String  @unique
  password String
  phone    String?
  role     Role    @default(STUDENT)

  isPro Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payments Payment[]
}

model Plan {
  id          Int     @id @default(autoincrement())
  name        String
  price       Int
  description String?

  isActive Boolean @default(true)

  payments Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id Int @id @default(autoincrement())

  userId Int
  planId Int

  amount Int

  transactionId String?
  screenshotUrl String?

  status PaymentStatus @default(PENDING)

  adminNote String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])
}

model Lecture {
  id Int @id @default(autoincrement())

  title         String
  lectureNumber Int

  youtubeUrl String

  exam  String
  topic String

  isRecorded Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Material {
  id Int @id @default(autoincrement())

  title  String
  pdfUrl String

  exam  String
  topic String

  type MaterialType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PYQ {
  id Int @id @default(autoincrement())

  title  String
  pdfUrl String

  exam  String
  topic String

  year Int?

 status  String @default("Draft")
 
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model POTD {
  id Int @id @default(autoincrement())

  title String

  problemImageUrl  String
  hintImageUrl     String?
  solutionImageUrl String?

  exam  String
  topic String
  status String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MockTest {
  id Int @id @default(autoincrement())

  title String

  exam  String
  topic String

  externalUrl String

  isProOnly Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
